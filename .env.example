# Docker container name
CONTAINER_NAME=goproxy

# Ports
WEBUI_PORT=7800
SOCKS5_PORT=7801
HTTP_PORT=7802

# Credentials (WebUI password, proxy auth username/password) are NOT set here.
# On first boot the gateway generates random credentials, prints them to the
# container log exactly once, and stores them in config.json under DATA_DIR.
# Read them with:  docker compose logs goproxy | grep -A6 "首次启动"
# After first login, change them in the WebUI Settings panel.
# To reset credentials, delete config.json from the data volume and restart.

# Username DSL defaults
# DEFAULT_REGION applies when the proxy username has no -region- suffix.
# Example username: <base>-region-us-session-browser  (base = proxy auth username)
SESSION_TTL_MINUTES=10
DEFAULT_REGION=

# Geo filters
# ALLOWED_COUNTRIES takes priority when set, for example: US,JP,SG
ALLOWED_COUNTRIES=
# BLOCKED_COUNTRIES is used only when ALLOWED_COUNTRIES is empty.
BLOCKED_COUNTRIES=

# Health and retry behavior
HEALTH_CHECK_INTERVAL=5
MAX_RETRY=3

# Subscription and encrypted manual single-link conversion
SINGBOX_PATH=sing-box

# Optional local data directory. docker-compose sets DATA_DIR=/app/data inside the container.
# DATA_DIR=./data

# Timezone
TZ=Asia/Shanghai
