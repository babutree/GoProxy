# Copy to .env and adjust as needed:  cp .env.example .env
# docker compose reads .env automatically. Every value below has a built-in
# default, so an empty .env still works. Credentials are NOT configured here —
# see the note under "Credentials".

# Container name
CONTAINER_NAME=goproxy

# Host port mappings (container-internal ports are fixed at 7800/7801/7802)
WEBUI_PORT=7800
SOCKS5_PORT=7801
HTTP_PORT=7802

# Credentials
# WebUI password and proxy auth username/password are NOT set here.
# On first boot the gateway generates random credentials, prints them to the
# container log exactly once, and stores them in config.json under the data volume.
#   docker compose logs goproxy | grep -A6 "首次启动"
# After first login, change them in the WebUI Settings panel.
# To reset, delete config.json from the data volume and restart.

# Sticky session TTL in minutes
SESSION_TTL_MINUTES=10

# Max concurrent sticky sessions per proxy node (0 = unlimited)
# MAX_SESSIONS_PER_PROXY=0

# Quiet period (minutes) after a new session first-bind before other new sessions
# may bind the same node (0 = disabled). Sticky hits ignore cooldown.
# PROXY_COOLDOWN_MINUTES=0

# Default region for usernames without a -region- suffix (empty = any region)
DEFAULT_REGION=

# Geo filters (comma-separated ISO alpha-2 codes)
# ALLOWED_COUNTRIES takes priority when set, e.g. US,JP,SG
ALLOWED_COUNTRIES=
# BLOCKED_COUNTRIES applies only when ALLOWED_COUNTRIES is empty.
BLOCKED_COUNTRIES=CN

# Health-check interval (minutes) and upstream retry count
HEALTH_CHECK_INTERVAL=5
MAX_RETRY=3

# Independent sing-box processes for encrypted tunnel nodes (default 4)
# SINGBOX_SHARD_COUNT=4

# Container timezone
TZ=Asia/Shanghai
